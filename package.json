{
  "name": "cicd-engine",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "worker": "node src/worker.js",
    "dev": "nodemon src/server.js",
    "dev:worker": "nodemon src/worker.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --runInBand --watch",
    "test:coverage": "jest --runInBand --coverage",
    "migrate": "node db/migrate.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "worker:prod": "NODE_ENV=production node src/worker.js",
    "seed:admin": "node db/seed-admin.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "simple-git": "^3.21.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
